{
  "expo": {
    "name": "QR Reader",
    "slug": "qr-reader-ondrej",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "qrreader",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ondrejlevy.qrreader.RW4Q5ZGHM2",
      "buildNumber": "6",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is needed to scan QR codes.",
        "NSPhotoLibraryUsageDescription": "Photo library access is needed to scan QR codes from images.",
        "NSPhotoLibraryAddUsageDescription": "Permission to save images.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.ondrejlevy.qrreader",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow QR Reader to access your camera to scan QR codes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow QR Reader to access your photos to scan QR codes from images."
        }
      ],
      "expo-localization",
      "expo-font",
      "./plugins/withDevelopmentSigning"
    ],
    "extra": {
      "eas": {
        "projectId": "af17679a-ab44-43b7-8d8a-decac1257ad4"
      }
    },
    "owner": "dupl3xx"
  }
}
