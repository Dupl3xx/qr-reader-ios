{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "buildConfiguration": "Debug",
        "credentialsSource": "local"
      },
      "config": ".eas/build/development.yml"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "buildConfiguration": "Release",
        "credentialsSource": "remote"
      }
    },
    "production": {
      "distribution": "store",
      "ios": {
        "buildConfiguration": "Release",
        "credentialsSource": "remote",
        "image": "latest"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "RW4Q5ZGHM2",
        "ascAppId": "6761314985",
        "ascApiKeyId": "W2MX3598UA",
        "ascApiKeyIssuerId": "f35c313a-2f67-4cd2-b11c-bbd0250ae405",
        "ascApiKeyPath": ".eas/asc-api-key.p8"
      }
    }
  }
}
